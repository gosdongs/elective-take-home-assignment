{
  "name": "@elective/server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run generate && tsx watch src/server.ts",
    "generate": "tsoa spec-and-routes",
    "build": "npm run generate && tsc && mkdir -p dist/generated && cp src/generated/openapi.json dist/generated/openapi.json",
    "start": "node dist/server.js",
    "test": "npm run generate && vitest run"
  },
  "dependencies": {
    "@tsoa/runtime": "^6.6.0",
    "express": "^4.21.2",
    "swagger-ui-express": "^5.0.1",
    "tsoa": "^6.6.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.8",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8"
  }
}
